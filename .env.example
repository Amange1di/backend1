# Example .env for PostgreSQL configuration
# Option A: single DATABASE_URL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# Option B: individual DB_* variables (used if DATABASE_URL is not set)
DB_ENGINE=postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Load this file in development with python-dotenv or your process manager.